# Копия для docker compose (файл .env в корне репозитория подхватывается автоматически).

# Публичный URL без слэша в конце (браузер, presigned MinIO, MinIO Console, SvelteKit ORIGIN)
# Локально: http://localhost
# Сервер:   http://5.42.118.121
PUBLIC_ORIGIN=http://localhost

# Presigned ссылки на файлы: тот же хост + префикс nginx /minio-s3/
S3_PUBLIC_ENDPOINT_URL=http://localhost/minio-s3

# CORS для API (добавьте свой домен/IP)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# Database (если бэкенд не в compose — свой URL)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mrp_bom_orders

# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# SEED_ON_STARTUP=true
